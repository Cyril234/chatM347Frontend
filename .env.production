# Diese Werte werden beim Docker-Build via --build-arg gesetzt
# (Dockerfile ARG VITE_GATEWAY_URL / VITE_WS_URL, gespeist aus den CI-Secrets
#  PUBLIC_URL bzw. PUBLIC_WS_URL). Tatsaechlich gesetzte Build-Args haben Vorrang
#  vor diesen Defaults.
#
# Leer = same-origin (Frontend laeuft hinter dem Reverse-Proxy/Caddy, der /api bzw.
# /ws an den Gateway weiterleitet). Bei direktem Zugriff stattdessen die volle
# Gateway-URL eintragen, z. B. VITE_GATEWAY_URL=https://<host> und
# VITE_WS_URL=wss://<host>/ws
VITE_GATEWAY_URL=
VITE_WS_URL=
