# Lokale Entwicklung: beide Variablen leer lassen.
# Dann laufen alle Requests same-origin ueber den Vite-Dev-Proxy (siehe vite.config.ts):
#   /auth, /users  -> Gateway            (http://localhost:8080)
#   /ws/chat       -> Websocket-Service  (ws://localhost:3004)
# Dadurch sind Cookies first-party und es gibt keine CORS-Probleme.
VITE_GATEWAY_URL=
VITE_WS_URL=
